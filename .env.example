# SoilConnect — environment configuration
# Copy to ".env" and fill in. Everything here has a safe default for local dev,
# so the app runs with NO .env at all. Set these for staging/production.

# ----------------------------------------------------------------------------
# Core
# ----------------------------------------------------------------------------
# Public URL of the frontend (used in email links: verify, password reset).
# Local dev default: http://localhost:5173
APP_URL=https://app.yourdomain.com

# Comma-separated list of browser origins allowed to call the API (CORS).
# Leave UNSET in local dev (the server reflects the caller's origin).
# In production set this to your frontend URL(s). "*" = allow any (not advised).
CORS_ORIGIN=https://app.yourdomain.com

# ----------------------------------------------------------------------------
# Auth / verification
# ----------------------------------------------------------------------------
# Whether new users must confirm their email before they can post/bid.
#   true  = enforce (use once real SMTP is configured)
#   false = auto-verify everyone (beta default when no SMTP)
# If unset, defaults to ON when SMTP is configured, OFF otherwise.
REQUIRE_VERIFICATION=false

# ----------------------------------------------------------------------------
# Email (SMTP). If unset, the app uses an Ethereal TEST inbox: nothing is
# actually delivered, and verification/reset links are returned in the API
# response so flows still work. Set all four to send real mail.
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.youremailprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM=SoilConnect <no-reply@yourdomain.com>

# ----------------------------------------------------------------------------
# Billing (subscriptions). Defaults keep the app FREE for everyone until the
# user-count threshold is reached. Stripe is the intended real processor.
# ----------------------------------------------------------------------------
# Force paid mode on regardless of user count (true/false).
BILLING_ENABLED=false
# Number of accounts after which paid mode auto-activates.
FREE_USER_THRESHOLD=100
# Free posts/month for end users before a subscription is required.
FREE_POSTS_PER_MONTH=1
# Display-only price labels shown in the UI.
ENDUSER_PRICE=$10–15/mo
HAULER_PRICE=$250–400/mo

# ----------------------------------------------------------------------------
# Optional integrations
# ----------------------------------------------------------------------------
# OpenAI key for the in-app assistant (/api/chat). Optional.
OPENAI_API_KEY=
