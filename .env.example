# SoilConnect — environment configuration
# Copy to ".env" and fill in. Everything here has a safe default for local dev,
# so the app runs with NO .env at all. Set these for staging/production.

# ----------------------------------------------------------------------------
# Core / deployment
# ----------------------------------------------------------------------------
# production = the Express server also serves the built React app from dist/
# (single-service deploy). Leave unset for local dev (Vite serves the frontend).
NODE_ENV=production

# Port the server listens on. Most hosts (e.g. Render) inject this automatically.
# Local default: 3001
PORT=3001

# Directory for the JSON datastore (data.json). In production point this at a
# MOUNTED PERSISTENT DISK so data survives redeploys (otherwise it's wiped each
# deploy). Alternatively set DATA_FILE to a full file path. Local default: ./
DATA_DIR=/data

# Force-enable serving dist/ even when NODE_ENV isn't "production" (rarely needed).
# SERVE_STATIC=true

# Public URL of the app (used in email links: verify, password reset).
# Single-service deploy: this is your one deployed URL. Local dev: http://localhost:5173
APP_URL=https://app.yourdomain.com

# FRONTEND build-time setting (note the VITE_ prefix). Where the browser/app
# should reach the API. Leave UNSET for the normal single-service web deploy
# (frontend + API share one address, so a relative "/api" path just works).
# Set it only for a SPLIT setup or a native phone-app build, e.g.
#   VITE_API_URL=https://soilconnect.onrender.com
# VITE_API_URL=

# Comma-separated list of browser origins allowed to call the API (CORS).
# Leave UNSET in local dev (the server reflects the caller's origin).
# In production set this to your frontend URL(s). "*" = allow any (not advised).
CORS_ORIGIN=https://app.yourdomain.com

# ----------------------------------------------------------------------------
# Auth / verification
# ----------------------------------------------------------------------------
# Whether new users must confirm their email before they can post/bid.
#   true  = enforce (use once real SMTP is configured)
#   false = auto-verify everyone (beta default when no SMTP)
# If unset, defaults to ON when SMTP is configured, OFF otherwise.
REQUIRE_VERIFICATION=false

# ----------------------------------------------------------------------------
# Email (SMTP). If unset, the app uses an Ethereal TEST inbox: nothing is
# actually delivered, and verification/reset links are returned in the API
# response so flows still work. Set all four to send real mail.
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.youremailprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM=SoilConnect <no-reply@yourdomain.com>

# ----------------------------------------------------------------------------
# Billing (subscriptions). Defaults keep the app FREE for everyone until the
# user-count threshold is reached. Stripe is the intended real processor.
# ----------------------------------------------------------------------------
# Force paid mode on regardless of user count (true/false).
BILLING_ENABLED=false
# Number of accounts after which paid mode auto-activates.
FREE_USER_THRESHOLD=100
# Free posts/month for end users before a subscription is required.
FREE_POSTS_PER_MONTH=1
# Display-only price labels shown in the UI.
ENDUSER_PRICE=$10–15/mo
HAULER_PRICE=$250–400/mo

# ----------------------------------------------------------------------------
# Optional integrations
# ----------------------------------------------------------------------------
# OpenAI key for the in-app assistant (/api/chat). Optional.
OPENAI_API_KEY=

# Where in-app beta feedback is emailed. Defaults to alex@eclsite.com.
FEEDBACK_TO=alex@eclsite.com

# ----------------------------------------------------------------------------
# Error monitoring (Sentry) — optional. Leave unset to disable entirely.
# Create a free project at sentry.io and paste its DSN. Two vars (same DSN value):
#   SENTRY_DSN       -> backend (server) errors
#   VITE_SENTRY_DSN  -> frontend (browser) errors (baked in at build time)
# ----------------------------------------------------------------------------
SENTRY_DSN=
VITE_SENTRY_DSN=
